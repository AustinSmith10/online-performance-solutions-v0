# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from `npx supabase status` after running `npx supabase start`
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Contact address shown on client-facing "contact support" links (locked account,
# expired approval link, low credit, etc). Defaults to support@ddeg.com.au if unset.
NEXT_PUBLIC_SUPPORT_EMAIL=support@ddeg.com.au

# ─── Database (pg-boss worker) ────────────────────────────────────────────────
# Points to the Supabase postgres instance
# Local: postgresql://postgres:postgres@localhost:54322/postgres
# Production (Railway): use the Supabase SESSION pooler (port 5432), not the direct
# db.<ref>.supabase.co connection — pg-boss needs LISTEN/NOTIFY + advisory locks,
# which only work in session mode, not transaction mode (port 6543).
# Format: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# (Get the exact string from Supabase Dashboard → Project Settings → Database → Connection string → Session pooler)
DATABASE_URL=

# ─── Email ───────────────────────────────────────────────────────────────────
# Postmark — outbound transactional email + inbound webhook (email submission flow)
POSTMARK_SERVER_TOKEN=
POSTMARK_INBOUND_HASH=

# The From address on every outbound email. Must be a verified Sender Signature
# (or on a verified sending domain) in Postmark, or sends are rejected.
# Defaults to "OPS <noreply@ddeg.com.au>" if unset — set it explicitly in production.
EMAIL_FROM=

# Basic Auth credentials embedded in the inbound webhook URL configured in Postmark
# (https://<user>:<password>@yourdomain.com/api/webhooks/email). Required in all
# environments — if unset, the webhook logs a warning and skips the auth check (dev only).
POSTMARK_INBOUND_WEBHOOK_USER=
POSTMARK_INBOUND_WEBHOOK_PASSWORD=

# ─── PDF Generation (Gotenberg) ──────────────────────────────────────────────
# Local: http://localhost:3001  |  Railway: http://$RAILWAY_PRIVATE_DOMAIN:3000
GOTENBERG_URL=http://localhost:3001

# ─── AI (Claude API) ─────────────────────────────────────────────────────────
# Used for OCR/field extraction from uploaded POs and building plans
ANTHROPIC_API_KEY=
